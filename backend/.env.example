SECRET_KEY=change-this-to-a-random-secret-in-production
DATABASE_URL=sqlite:///./sentinel.db

# Get a free key at https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=
ABUSEIPDB_BASE_URL=https://api.abuseipdb.com/api/v2

# Leave true to use realistic mock IP reputation data instead of calling AbuseIPDB
USE_MOCK_REPUTATION=true
